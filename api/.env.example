# Flask Backend Environment Variables
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
PORT=5000

# Admin CMS
# Use ADMIN_PASSWORD_HASH in production when possible.
ADMIN_PASSWORD=change-this-admin-password
# ADMIN_PASSWORD_HASH=generate-with-werkzeug
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=False

# CORS origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,https://your-domain.com

# Database
DATABASE_URL=sqlite:///bynolo.db

# Uploads and screenshots
UPLOAD_FOLDER=instance/uploads
MAX_UPLOAD_MB=8
# After installing requirements, run:
# python -m playwright install chromium

# Email settings (for contact form notifications - optional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_USERNAME=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# NOTIFICATION_EMAIL=your-email@gmail.com
